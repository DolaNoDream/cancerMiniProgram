/* pages/colorectal/colorectal.wxss */
.container {
    padding: 20rpx;
    background-color: #f5f7fa;
    min-height: 100vh;
  }
  
  .form-header {
    padding: 30rpx 0;
    text-align: center;
    margin-bottom: 20rpx;
  }
  
  .title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 15rpx;
  }
  
  .subtitle {
    font-size: 28rpx;
    color: #666;
  }
  
  .question-group {
    display: flex;
    margin-bottom: 30rpx;
    background-color: #fff;
    border-radius: 16rpx;
    padding: 25rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  }
  
  .question-number {
    font-size: 30rpx;
    font-weight: bold;
    color: #1677ff;
    margin-right: 15rpx;
    min-width: 40rpx;
  }
  
  .question-content {
    flex: 1;
  }
  
  .question-text {
    font-size: 30rpx;
    color: #333;
    margin-bottom: 20rpx;
    line-height: 1.5;
  }
  
  .radio-group {
    display: flex;
    flex-direction: column;
    gap: 15rpx;
  }
  
  .radio-item {
    display: flex;
    align-items: center;
    font-size: 28rpx;
    color: #555;
    padding: 10rpx 0;
  }
  
  .radio-item radio {
    margin-right: 15rpx;
    transform: scale(1.2);
  }
  
  .conditional-input {
    margin-left: 10rpx;
    padding: 12rpx 15rpx;
    border: 1rpx solid #ddd;
    border-radius: 8rpx;
    font-size: 26rpx;
    flex: 1;
    min-width: 300rpx;
  }
  
  .sub-question {
    display: flex;
    margin: 30rpx 0 30rpx 20rpx;
    padding-top: 30rpx;
    border-top: 1rpx dashed #eee;
  }
  
  .sub-question:first-child {
    margin-top: 10rpx;
    padding-top: 0;
    border-top: none;
  }
  
  .sub-question-number {
    font-size: 26rpx;
    color: #666;
    margin-right: 15rpx;
    min-width: 30rpx;
  }
  
  .sub-question-content {
    flex: 1;
  }
  
  .sub-question-text {
    font-size: 26rpx;
    color: #444;
    margin-bottom: 15rpx;
    line-height: 1.5;
  }
  
  .submit-btn {
    width: 100%;
    height: 90rpx;
    line-height: 90rpx;
    font-size: 32rpx;
    background-color: #1677ff;
    color: #fff;
    border-radius: 16rpx;
    margin: 40rpx 0 20rpx;
  }
  
  .submit-btn::after {
    border: none;
  }
  