/* pages/questionnaire/questionnaire.wxss */
.container {
    padding: 20rpx 30rpx;
    background-color: #f5f5f5;
    min-height: 100vh;
  }
  
  .section-title {
    font-size: 34rpx;
    font-weight: bold;
    color: #337ab7;
    margin: 30rpx 0 20rpx;
    padding-left: 10rpx;
    border-left: 6rpx solid #337ab7;
  }
  
  .question-item {
    background-color: #fff;
    padding: 30rpx;
    margin-bottom: 20rpx;
    border-radius: 10rpx;
    box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  }
  
  .question {
    font-size: 32rpx;
    margin-bottom: 20rpx;
    color: #333;
    line-height: 1.5;
  }
  
  .options {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
  }
  
  .radio {
    display: flex;
    align-items: center;
    font-size: 28rpx;
    color: #666;
    padding: 10rpx 0;
    flex-wrap: wrap;
  }
  
  .radio radio {
    margin-right: 15rpx;
    transform: scale(0.8);
  }
  
  .inline-input {
    flex: 1;
    min-width: 300rpx;
    margin-left: 10rpx;
    padding: 10rpx;
    border: 1rpx solid #ddd;
    border-radius: 5rpx;
    font-size: 26rpx;
  }
  
  .small-input {
    width: 100rpx;
    margin: 0 5rpx;
    padding: 8rpx;
    border: 1rpx solid #ddd;
    border-radius: 5rpx;
    font-size: 26rpx;
    text-align: center;
  }
  
  .normal-input {
    flex: 1;
    padding: 10rpx;
    border: 1rpx solid #ddd;
    border-radius: 5rpx;
    font-size: 26rpx;
  }
  
  .condition-fields {
    margin-top: 15rpx;
    margin-left: 50rpx;
    display: flex;
    flex-direction: column;
    gap: 15rpx;
  }
  
  .field-item {
    display: flex;
    align-items: center;
    font-size: 28rpx;
    color: #666;
  }
  
  .field-label {
    margin-right: 10rpx;
    white-space: nowrap;
  }
  
  .submit-btn {
    margin: 40rpx 0;
    width: 100%;
    height: 80rpx;
    line-height: 80rpx;
    background-color: #337ab7;
    color: white;
    font-size: 32rpx;
    border-radius: 10rpx;
  }

  /* 对话框遮罩层 */
.dialog-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 999;
    pointer-events: auto;
    overflow: hidden;
  }
  
  /* 对话框容器 */
  .dialog-container {
    width: 80%;
    max-width: 600rpx;
    height: 50vh;
    background-color: #fff;
    border-radius: 20rpx;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  
  /* 标题样式 */
  .dialog-title {
    padding: 30rpx;
    text-align: center;
    border-bottom: 1px solid #eee;
  }
  
  .high-risk {
    color: #e63946;
    font-size: 36rpx;
    font-weight: bold;
  }
  
  .low-risk {
    color: #43aa8b;
    font-size: 36rpx;
    font-weight: bold;
  }
  
  /* 建议内容容器 */
  .suggestion-container {
    flex: 1;
    padding: 30rpx;
    box-sizing: border-box;
  }
  
  /* 滚动区域 */
  .suggestion-scroll {
    height: 100%;
    font-size: 28rpx;
    line-height: 1.6;
    color: #333;
    padding: 10rpx;
  }
  
  /* 按钮区域 */
  .dialog-buttons {
    display: flex;
    border-top: 1px solid #eee;
  }
  
  /* 按钮样式 */
  .dialog-btn {
    flex: 1;
    height: 100rpx;
    line-height: 100rpx;
    padding: 0;
    margin: 0;
    border-radius: 0;
    border: none;
    font-size: 32rpx;
    background-color: transparent;
    color: #1677ff;
  }
  
  /* 按钮分割线 */
  .dialog-btn::after {
    border: none;
  }
  
  .dialog-btn:first-child {
    border-right: 1px solid #eee;
  }
  