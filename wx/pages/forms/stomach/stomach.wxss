/* pages/forms/stomach/stomach.wxss */
.container {
    padding: 20rpx 30rpx;
    background-color: #f5f5f5;
    min-height: 100vh;
  }
  
  .section-title {
    font-size: 34rpx;
    font-weight: bold;
    color: #337ab7;
    margin: 30rpx 0 20rpx;
    padding-left: 10rpx;
    border-left: 6rpx solid #337ab7;
  }
  
  .question-item {
    background-color: #fff;
    padding: 30rpx;
    margin-bottom: 20rpx;
    border-radius: 10rpx;
    box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  }
  
  .question {
    font-size: 32rpx;
    margin-bottom: 20rpx;
    color: #333;
    line-height: 1.5;
  }
  
  .question-sub {
    font-size: 28rpx;
    margin-bottom: 20rpx;
    color: #666;
    padding-left: 20rpx;
  }
  
  .options {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
  }
  
  .radio {
    display: flex;
    align-items: center;
    font-size: 28rpx;
    color: #666;
    padding: 10rpx 0;
    flex-wrap: wrap;
  }
  
  .radio radio, .radio checkbox {
    margin-right: 15rpx;
    transform: scale(0.8);
  }
  
  .inline-input {
    flex: 1;
    min-width: 300rpx;
    margin-left: 10rpx;
    padding: 10rpx;
    border: 1rpx solid #ddd;
    border-radius: 5rpx;
    font-size: 26rpx;
  }
  
  .small-input {
    width: 100rpx;
    margin: 0 5rpx;
    padding: 8rpx;
    border: 1rpx solid #ddd;
    border-radius: 5rpx;
    font-size: 26rpx;
    text-align: center;
  }
  
  .normal-input {
    width: 100%;
    padding: 10rpx;
    border: 1rpx solid #ddd;
    border-radius: 5rpx;
    font-size: 26rpx;
    margin-top: 10rpx;
  }
  
  .condition-fields {
    margin-top: 15rpx;
    margin-left: 50rpx;
    display: flex;
    flex-direction: column;
    gap: 15rpx;
  }
  
  .field-item {
    display: flex;
    align-items: center;
    font-size: 28rpx;
    color: #666;
  }
  
  .field-label {
    margin-right: 10rpx;
    white-space: nowrap;
    font-size: 28rpx;
  }
  
  .submit-btn {
    margin: 40rpx 0;
    width: 100%;
    height: 80rpx;
    line-height: 80rpx;
    background-color: #337ab7;
    color: white;
    font-size: 32rpx;
    border-radius: 10rpx;
  }
  
  .sub-question {
    margin: 20rpx 0;
    padding-left: 20rpx;
  }
  
  .hint-text {
    font-size: 26rpx;
    color: #666;
    margin: 5rpx 0;
    padding-left: 20rpx;
  }