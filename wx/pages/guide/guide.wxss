/* pages/guide/guide.wxss */
.guide-container {
    min-height: 100vh;
    background-color: #f5f7fa;
    padding: 20rpx;
  }
  
  .page-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    margin: 30rpx 20rpx;
  }
  
  .card-container {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
    padding: 10rpx 20rpx;
  }
  
  .guide-card {
    display: flex;
    align-items: center;
    background-color: #ffffff;
    border-radius: 16rpx;
    padding: 25rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
    transition: transform 0.2s;
  }
  
  .guide-card:active {
    transform: scale(0.98);
  }
  
  .card-icon {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    background-color: #e8f4fd;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 25rpx;
  }
  
  .icon {
    font-size: 40rpx;
    color: #409eff;
  }
  
  .card-content {
    flex: 1;
  }
  
  .card-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 8rpx;
  }
  
  .card-desc {
    font-size: 26rpx;
    color: #666;
    line-height: 1.4;
  }
  
  .card-arrow {
    font-size: 30rpx;
    color: #ccc;
    margin-left: 10rpx;
  }