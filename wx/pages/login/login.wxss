/* pages/login/login.wxss */
.container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background-color: #f5f5f5;
    padding: 0 30rpx;
  }
  
  .login-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 100rpx;
  }
  
  .logo {
    width: 200rpx;
    height: 200rpx;
    margin-bottom: 40rpx;
    border-radius: 50%;
    box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
  }
  
  .title {
    font-size: 36rpx;
    color: #333;
    font-weight: bold;
  }
  
  .login-btn {
    width: 100%;
    height: 90rpx;
    line-height: 90rpx;
    background-color: #07c160;
    color: #fff;
    font-size: 32rpx;
    border-radius: 45rpx;
    margin-bottom: 30rpx;
  }
  
  .login-tip {
    font-size: 28rpx;
    color: #ff4d4f;
    text-align: center;
    padding: 10rpx;
  }
  