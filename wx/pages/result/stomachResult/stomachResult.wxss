/* pages/result/stomachResult/stomachResult.wxss */
.container {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background-color: #f5f5f5;
    padding: 20rpx;
  }
  
  .result-container {
    flex: 1;
    background-color: #fff;
    border-radius: 16rpx;
    padding: 40rpx 30rpx;
    margin: 30rpx 0;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  }
  
  .result-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    text-align: center;
    margin-bottom: 50rpx;
    padding-bottom: 20rpx;
    border-bottom: 1px solid #eee;
  }
  
  .result-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .risk-level {
    font-size: 40rpx;
    font-weight: bold;
    margin-bottom: 40rpx;
    padding: 15rpx 30rpx;
    border-radius: 8rpx;
  }
  
  .high-risk {
    color: #e53e3e;
    background-color: #fff5f5;
    border: 1px solid #fed7d7;
  }
  
  .low-risk {
    color: #22c55e;
    background-color: #f0fdf4;
    border: 1px solid #bbf7d0;
  }
  
  .suggestion-scroll {
    width: 100%;
    height: 800rpx;
    padding: 30rpx;
    background-color: #fafafa;
    border-radius: 12rpx;
    border: 1px solid #eee;
  }
  
  .suggestion-content {
    font-size: 28rpx;
    color: #555;
    line-height: 1.8;
  }
  
  .suggestion-content text {
    display: block;
    margin-bottom: 20rpx;
  }
  
  .suggestion-list {
    margin-top: 10rpx;
    padding-left: 30rpx;
  }
  
  .suggestion-list text {
    margin-bottom: 15rpx;
  }
  
  .nav-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: auto;
    padding: 20rpx 0 40rpx;
  }
  
  .nav-btn {
    width: 45%;
    height: 90rpx;
    line-height: 90rpx;
    text-align: center;
    font-size: 32rpx;
    border-radius: 12rpx;
    border: none;
  }
  
  .home-btn {
    background-color: #fff;
    color: #333;
    border: 1px solid #ddd;
  }
  
  .advice-btn {
    background-color: #007aff;
    color: #fff;
  }
  